---
import projects from "../data/projects.json";

const codingProjects = projects.filter(p => p.category === 'coding');
const creativeProjects = projects.filter(p => p.category === 'creative');
---

<div id="page-container" class="font-mono max-w-5xl mx-auto px-8 pt-16 pb-8 select-none">
    <h1 class="stagger-item text-center text-xl font-bold pb-10 mb-16" style="--delay: 0ms">
      <a href="https://github.com/sawmm" target="_blank" rel="noopener noreferrer" class="hover-underline">Sam Huisman</a>
    </h1>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    
    <!-- Left Column: Project List -->
    <div>
      <!-- Coding Projects -->
      <div class="mb-8">
        <h2 class="text-sm font-bold mb-4 opacity-60 uppercase tracking-wider stagger-item" style="--delay: 50ms">Coding</h2>
        <ul class="space-y-3">
          {codingProjects.map((project, index) => (
            <li 
              class="stagger-item cursor-pointer p-3"
              style={`--delay: ${(index + 2) * 100}ms`}
            >
              <span data-id={project.id} class="hover-underline focus:font-bold">{project.title}</span>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Creative Projects -->
      <div>
        <h2 class="text-sm font-bold mb-4 opacity-60 uppercase tracking-wider stagger-item" style={`--delay: ${(codingProjects.length + 2) * 100}ms`}>Creative</h2>
        <ul class="space-y-3">
          {creativeProjects.map((project, index) => (
            <li 
              class="stagger-item cursor-pointer p-3"
              style={`--delay: ${(codingProjects.length + index + 3) * 100}ms`}
            >
              <span data-id={project.id} class="hover-underline focus:font-bold">{project.title}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
    
    <!-- Right Column: Project Details -->
    <div id="detail-view" class="stagger-item p-6 min-h-[400px]" style={`--delay: ${(projects.length + 3) * 100}ms`}>
    </div>
    
  </div>
</div>

<script define:vars={{ projects }}>
  const items = document.querySelectorAll('[data-id]');
  const detailView = document.getElementById('detail-view');
  
  items.forEach(item => {
    item.addEventListener('click', () => {
      const id = item.dataset.id;
      const project = projects.find(p => p.id === id);
      
      if (project && detailView) {
        // Handle both images and videos
        const mediaHtml = project.media && project.media.length > 0 
          ? `<div class="grid grid-cols-2 gap-4 mb-4 opacity-0 transition-opacity duration-500" id="media-container">${project.media.map(media => {
              if (media.endsWith('.mp4') || media.endsWith('.webm') || media.endsWith('.mov')) {
                return `<video src="${media}" autoplay loop muted playsinline class="w-full rounded" />`;
              } else {
                return `<img src="${media}" alt="${project.title}" class="w-full rounded" />`;
              }
            }).join('')}</div>`
          : '';
        
        // Fallback to images if no media field
        const imagesHtml = !project.media && project.images && project.images.length > 0 
          ? `<div class="grid grid-cols-2 gap-4 mb-4 opacity-0 transition-opacity duration-500" id="images-container">${project.images.map(img => `<img src="${img}" alt="${project.title}" class="w-full rounded" />`).join('')}</div>`
          : '';
        
        const githubHtml = project.github 
          ? `<a href="${project.github}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mb-4 text-sm hover:opacity-70 transition-opacity" title="View on GitHub">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              <span>View on GitHub</span>
            </a>`
          : '';
        
        detailView.innerHTML = `
          <div class="opacity-0 transition-all duration-300 ease-out translate-y-2" id="project-content">
            <h2 class="text-2xl font-bold mb-4">${project.title}</h2>
            ${mediaHtml || imagesHtml}
            ${githubHtml}
            <p>${project.description}</p>
          </div>
        `;
        items.forEach(itm => itm.classList.remove('font-bold'));
        item.classList.add('font-bold');

        // Animate in the content immediately
        requestAnimationFrame(() => {
          const content = document.getElementById('project-content');
          if (content) {
            content.classList.remove('opacity-0', 'translate-y-2');
          }
        });

        // Wait for media to load then fade them in
        const container = document.getElementById('media-container') || document.getElementById('images-container');
        if (container) {
          const mediaElements = container.querySelectorAll('img, video');
          let loadedCount = 0;
          
          mediaElements.forEach(el => {
            if (el.tagName === 'VIDEO') {
              el.addEventListener('loadeddata', () => {
                loadedCount++;
                if (loadedCount === mediaElements.length) {
                  container.classList.remove('opacity-0');
                }
              });
            } else {
              if (el.complete) {
                loadedCount++;
              } else {
                el.addEventListener('load', () => {
                  loadedCount++;
                  if (loadedCount === mediaElements.length) {
                    container.classList.remove('opacity-0');
                  }
                });
              }
            }
          });
          
          // If all already loaded, show immediately
          if (loadedCount === mediaElements.length) {
            container.classList.remove('opacity-0');
          }
        }
      }
    });
  });

  // Stagger animation is handled by CSS
</script>

<style>
.hover-underline {
  display: inline;
  text-decoration: none;
  background-image: linear-gradient(currentColor, currentColor);
  background-position: 0% 100%;
  background-repeat: no-repeat;
  background-size: 0% 2px;
  transition: background-size 0.3s ease;
  -webkit-box-decoration-break: clone;
  box-decoration-break: clone;
}
.hover-underline:hover {
  background-size: 100% 2px;
}

:global(body) {
  background-color: #edede9;
  color: #47545c
}

.stagger-item {
  opacity: 0;
  transform: translateY(20px);
  animation: stairReveal 0.5s ease-out forwards;
  animation-delay: var(--delay);
}

@keyframes stairReveal {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

</style>
